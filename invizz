pluginManagement {
    repositories {
        maven {
            name = 'Fabric'
            url = 'https://maven.fabricmc.net/'
        }
        mavenCentral()
        gradlePluginPortal()
    }
}
plugins {
    id 'fabric-loom' version '1.7-SNAPSHOT'
    id 'maven-publish'
}

version = project.mod_version
group = project.maven_group

base {
    archivesName = project.archives_base_name
}

dependencies {
    minecraft "com.mojang:minecraft:${project.minecraft_version}"
    mappings "net.fabricmc:yarn:${project.yarn_mappings}:v2"
    modImplementation "net.fabricmc:fabric-loader:${project.loader_version}"
    modImplementation "net.fabricmc.fabric-api:fabric-api:${project.fabric_version}"
}

processResources {
    inputs.property "version", project.version
    filesMatching("fabric.mod.json") {
        expand "version": inputs.properties.version
    }
}

tasks.withType(JavaCompile).configureEach {
    it.options.release = 21
}

java {
    withSourcesJar()
    sourceCompatibility = JavaVersion.VERSION_21
    targetCompatibility = JavaVersion.VERSION_21
}
org.gradle.jvmargs=-Xmx2G
org.gradle.parallel=true

minecraft_version=1.21.1
yarn_mappings=1.21.1+build.3
loader_version=0.16.9

mod_version=2.0.0
maven_group=com.mod.invisiblesight
archives_base_name=invisible-sight

fabric_version=0.102.0+1.21.1
{
  "schemaVersion": 1,
  "id": "er1ikhangorunmezgorme",
  "version": "${version}",
  "name": "Er1ikHanGorunmezGorme",
  "description": "Allows you to see invisible entities.",
  "authors": ["User"],
  "environment": "client",
  "entrypoints": {
    "client": ["com.mod.invisiblesight.InvisibleSightClient"]
  },
  "mixins": ["invisiblesight.mixins.json"],
  "depends": {
