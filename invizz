  }
}
}
{
  "key.invisiblesight.toggle": "Toggle Invisibility Sight",
  "category.invisiblesight.general": "Invisible Sight Mod"
}
package com.mod.invisiblesight;

import net.fabricmc.api.ClientModInitializer;
import net.fabricmc.fabric.api.client.event.lifecycle.v1.ClientTickEvents;
import net.fabricmc.fabric.api.client.keybinding.v1.KeyBindingHelper;
import net.minecraft.client.MinecraftClient;
import net.minecraft.client.option.KeyBinding;
import net.minecraft.client.util.InputUtil;
import net.minecraft.text.Text;
import org.lwjgl.glfw.GLFW;

public class InvisibleSightClient implements ClientModInitializer {

    public static boolean isInvisibleVisible = false;

    private KeyBinding toggleKeyBinding;

    @Override
    public void onInitializeClient() {
        this.toggleKeyBinding = KeyBindingHelper.registerKeyBinding(new KeyBinding(
                "key.invisiblesight.toggle",
                InputUtil.Type.KEYSYM,
                GLFW.GLFW_KEY_V,
                "category.invisiblesight.general"
        ));

        ClientTickEvents.END_CLIENT_TICK.register(this::onEndTick);
    }

    private void onEndTick(MinecraftClient client) {
        while (this.toggleKeyBinding.wasPressed()) {
            isInvisibleVisible = !isInvisibleVisible;
            if (client.player != null) {
                client.player.sendMessage(Text.literal("Invisible Sight: " + (isInvisibleVisible ? "ON" : "OFF")), false);
            }
        }
    }
}
name: Build mod
on: [push, workflow_dispatch]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 21
      - run: chmod +x gradlew || true
      - run: gradle wrapper --gradle-version 8.8
      - run: ./gradlew build
      - uses: actions/upload-artifact@v4
        with:
          name: invisible-sight-jar
          path: build/libs/*.jar
